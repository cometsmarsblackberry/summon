# Database
DATABASE_URL=sqlite+aiosqlite:////data/reserve.db

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Cloud Providers (configure at least one)
VULTR_API_KEY=
GCORE_API_KEY=
GCORE_PROJECT_ID=0
ONIDEL_API_KEY=
ONIDEL_TEAM_ID=

# Steam
STEAM_API_KEY=

# hCaptcha (optional)
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# TF2 API Keys (get from demos.tf and logs.tf)
DEMOS_TF_APIKEY=
LOGS_TF_APIKEY=

# Branding
# SITE_NAME=Summon
# LOGO_URL=
# FAVICON_URL=
# OG_IMAGE_URL=
# DISCORD_URL=
# STEAM_GROUP_URL=
# CONTACT_EMAIL=
# RULES_URL=
# LOGIN_IMAGE_URL=
# LOGIN_IMAGE_WIDE_URL=
# CUSTOM_CONFIG_PREFIXES=

# Base URL — the public domain users see (used for Steam callbacks, links, etc.)
BASE_URL=http://localhost:8000

# FastAPI docs exposure (optional).
# Defaults to enabled on localhost and disabled for non-localhost BASE_URL values.
# EXPOSE_API_DOCS=false

# CDN provider (optional). Pass --bunny to deploy.sh to enable Bunny CDN
# integration (trusted proxy IPs, edge-only firewall). Leave unset for direct access.
# CDN_PROVIDER=

# Origin hostname (optional) — set this when behind a CDN.
# Caddy will serve on this hostname and get a TLS cert for it via HTTP-01,
# so no DNS API key is needed. Leave unset for direct access (no CDN).
# Example: ORIGIN_HOSTNAME=origin.example.com
# ORIGIN_HOSTNAME=

# Internal API key for SourceMod plugin to backend communication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=

# Temporary compatibility toggles for rolling upgrades.
# Leave disabled for the secure defaults.
# ALLOW_LEGACY_INTERNAL_API_KEY=false
# ALLOW_LEGACY_AGENT_QUERY_TOKEN=false

# Admin Steam IDs (comma-separated Steam64 IDs)
ADMIN_STEAM_IDS=

# Beta mode — when true, only admins can use the site
BETA_MODE=true

# IPinfo token for geolocation (optional — ping submissions work without it)
IPINFO_TOKEN=

# SSH public key for debugging access to cloud instances (optional)
SSH_PUBKEY=

# S3 storage for server logs (optional — Gcore S3 compatible)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=

# Logging (logs written to LOG_DIR/app.log with rotation)
LOG_DIR=/data/logs
LOG_LEVEL=INFO
