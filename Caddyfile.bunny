{
    servers {
        trusted_proxies bunny {
            interval 12h
            timeout 15s
        }
        client_ip_headers X-Real-Ip
    }
}

{$ORIGIN_HOSTNAME} {
    @static path /static/*
    header @static Cache-Control "public, max-age=2592000, immutable"

    reverse_proxy web:8000 {
        header_up X-Forwarded-For {client_ip}
    }
}
